# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.ruff_cache/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Environment variables
.env
.env.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Test coverage
.coverage
htmlcov/

# Logs
*.log

# Sample PDFs (add your own test files locally, avoid committing large binaries)
tests/samples/*.pdf
tests/samples/*.png
tests/samples/*.jpg

# Output files generated by the app (resultado*.json, etc.)
# Use --output flag to save results; esses arquivos sao locais
resultado*.json
output/

# PDFs e imagens gerados pelos testes automatizados
tests/generated/
